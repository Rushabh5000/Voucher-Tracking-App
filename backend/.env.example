# ════════════════════════════════════════════════════════════════
#  SETUP: Copy this file to ".env" and fill in your values.
#         The app will NOT start without a valid .env file.
#         Never commit the real .env — it contains secrets.
# ════════════════════════════════════════════════════════════════

# ─── Encryption ─────────────────────────────────────────────────
# AES-256-GCM key for encrypting sensitive voucher and card fields at rest.
# Must be exactly 64 hex characters (= 32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: losing this key means your existing data is unrecoverable. Back it up securely.
ENCRYPTION_KEY=replace-with-64-hex-chars

# ─── Authentication ─────────────────────────────────────────────
# Set these before deploying. The app will refuse to start the login
# endpoint if any of these are missing.
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
JWT_SECRET=replace-with-a-long-random-string

# ─── Database ───────────────────────────────────────────────────
# Matches the default credentials in docker-compose.yml
DATABASE_URL="postgresql://voucher_user:voucher_pass@localhost:5432/voucher_tracker"

# ─── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Email — optional, only needed for monthly report emails ────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
REPORT_RECIPIENT=your@gmail.com
EMAIL_FROM_NAME="Voucher Tracker"
EMAIL_FROM_ADDRESS=your@gmail.com

# ─── Monthly report cron (default: last day of month, 9 AM IST) ─
REPORT_CRON="0 9 28-31 * *"

# ─── Backup ─────────────────────────────────────────────────────
# Directory where all backups are stored.
# Source code is backed up on the 1st and 16th of each month.
# Database is backed up automatically on every server startup.
BACKUP_DIR=C:\Users\your-username\OneDrive\Backup-Vocuher-Tracking-Application
# Docker container name running PostgreSQL — used to run pg_dump inside the container.
# Only needed when PostgreSQL runs via Docker (pg_dump not installed on host).
DB_CONTAINER_NAME=vt-postgres

# ─── Audit ──────────────────────────────────────────────────────
# Number of months to retain audit log records.
# Records older than this are deleted on the 1st of each month.
AUDIT_RETENTION_MONTHS=12
