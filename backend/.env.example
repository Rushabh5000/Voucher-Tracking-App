# ─── Database ───────────────────────────────────────────────────
# Matches the default credentials in docker-compose.yml
DATABASE_URL="postgresql://voucher_user:voucher_pass@localhost:5432/voucher_tracker"

# ─── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Email — optional, only needed for monthly report emails ────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
REPORT_RECIPIENT=your@gmail.com
EMAIL_FROM_NAME="Voucher Tracker"
EMAIL_FROM_ADDRESS=your@gmail.com

# ─── Monthly report cron (default: last day of month, 9 AM IST) ─
REPORT_CRON="0 9 28-31 * *"
