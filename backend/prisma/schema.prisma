// Prisma schema for Voucher Tracker v2
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VoucherStatus {
  UNREDEEMED
  REDEEMED
  EXPIRED
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String
  role         String    @default("user")  // "user" | "guest"
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  vouchers             Voucher[]
  cards                Card[]
  autocompleteEntries  AutocompleteEntry[]

  @@index([role])
  @@index([expiresAt])
}

model Voucher {
  id                  String        @id @default(uuid())
  title               String        @default("")   // encrypted
  voucherCode         String                       // encrypted
  voucherCodeHash     String?                      // HMAC-SHA256 of normalised voucherCode for dedup (unique per user in app code)
  brand               String        @default("Uncategorized") // encrypted
  sourceProgramOrCard String        @default("")   // encrypted
  description         String        @default("")   // encrypted
  voucherType         String        @default("")
  value               Float?
  expiryDate          DateTime?
  issueDate           DateTime      @default(now())
  dateAdded           DateTime      @default(now())
  status              VoucherStatus @default(UNREDEEMED)
  redeemedAt          DateTime?
  emailId             String        @default("")   // encrypted
  cardOwner           String        @default("")   // encrypted
  cardName            String        @default("")   // encrypted
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  userId              String?
  user                User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dateAdded])
  @@index([status])
  @@index([userId])
}

model Card {
  id              String   @id @default(uuid())
  accountOwner    String
  cardName        String
  bank            String
  cardType        String   @default("Rupay Select")
  lastFourDigits  String
  email           String   @default("")
  mobileNumber    String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bank])
  @@index([accountOwner])
  @@index([userId])
}

// Stores unique values per field for smart autocomplete — scoped per user
model AutocompleteEntry {
  id        String   @id @default(uuid())
  field     String
  value     String
  count     Int      @default(1)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([field, value, userId])
  @@index([field])
  @@index([userId])
}

// Persists app-level key-value settings (e.g. last email sent timestamp)
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Records every mutating DB operation for auditing
model AuditLog {
  id         String   @id @default(uuid())
  action     String   // Human-readable: "Created voucher", "Deleted card"
  entity     String   // Model name: "Voucher", "Card", "AutocompleteEntry"
  entityId   String?  // UUID of the affected record
  details    String?  // e.g. "Amazon | AMZN-HDFC-Q1-2025"
  method     String
  path       String
  statusCode Int
  durationMs Int
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entity])
}
