{
  "name": "voucher-tracker-backend",
  "version": "2.0.0",
  "description": "Voucher Tracker API v2 — Node.js + Express + Prisma + PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "build":      "tsc",
    "start":      "node dist/index.js",
    "dev":        "ts-node-dev --respawn --transpile-only src/index.ts",
    "db:push":    "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio":  "prisma studio",
    "generate":   "prisma generate"
  },
  "dependencies": {
    "@prisma/client":  "^5.10.0",
    "cors":            "^2.8.5",
    "exceljs":         "^4.4.0",
    "express":         "^4.18.2",
    "node-cron":       "^3.0.3",
    "nodemailer":      "^6.9.9",
    "pdfkit":          "^0.15.0"
  },
  "devDependencies": {
    "@types/cors":       "^2.8.17",
    "@types/express":    "^4.17.21",
    "@types/node":       "^20.11.0",
    "@types/node-cron":  "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit":     "^0.13.3",
    "prisma":            "^5.10.0",
    "ts-node":           "^10.9.2",
    "ts-node-dev":       "^2.0.0",
    "typescript":        "^5.3.3"
  }
}
